# ScarpShield Environment Configuration
# Copy to .env and fill in your values

PROJECT=CounterScarp
TOOL=ScarpShield
WEBSITE=https://counterscarp.io

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=

# Slack alerts (optional)
SLACK_WEBHOOK_URL=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
